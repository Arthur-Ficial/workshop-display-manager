#!/usr/bin/env bash
# wdm pre-commit hook — enforces the iron law before every commit:
#  - release build clean under -warnings-as-errors
#  - full hermetic test suite green
#
# Activate by running once:
#     git config core.hooksPath scripts
#
# Bypass (NEVER for normal commits — only for documentation-only changes
# explicitly approved): git commit --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "pre-commit: release build (warnings-as-errors)..."
swift build -c release -Xswiftc -warnings-as-errors >/dev/null

echo "pre-commit: hermetic tests..."
swift test --parallel >/dev/null

# Verify the man page is in sync with the binary.
EXPECTED=$(.build/release/wdm manpage)
ACTUAL=$(cat man/wdm.1 2>/dev/null || true)
# The .TH header includes a date; strip the date line before diffing.
norm() { sed 's/^\.TH WDM 1 ".*"/\.TH WDM 1 "DATE"/'; }
if [ "$(printf '%s' "$EXPECTED" | norm)" != "$(printf '%s' "$ACTUAL" | norm)" ]; then
    echo "pre-commit: man/wdm.1 is out of date with the binary."
    echo "  Run: .build/release/wdm manpage > man/wdm.1 && git add man/wdm.1"
    exit 1
fi

echo "pre-commit: ok"
