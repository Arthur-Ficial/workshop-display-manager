#!/usr/bin/env bash
# wdm pre-commit hook — enforces the iron law before every commit:
#  - release build clean under -warnings-as-errors
#  - full hermetic test suite green
#
# Activate by running once:
#     git config core.hooksPath scripts
#
# Bypass (NEVER for normal commits — only for documentation-only changes
# explicitly approved): git commit --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

echo "pre-commit: ScreenCaptureKit import lint..."
# CI runs Swift 6.1 / macOS 15.5 SDK where SCShareableContent is non-Sendable;
# local builds on newer SDKs don't catch this, so guard at commit time.
if grep -RnE '^[[:space:]]*import[[:space:]]+ScreenCaptureKit[[:space:]]*$' \
        Sources/ Tests/ 2>/dev/null; then
    echo "pre-commit: bare 'import ScreenCaptureKit' found — must be"
    echo "            '@preconcurrency import ScreenCaptureKit' to keep CI"
    echo "            (Swift 6.1 / macOS 15.5 SDK) green."
    exit 1
fi

echo "pre-commit: lint-no-gui-logic..."
bash scripts/lint-no-gui-logic.sh

echo "pre-commit: lint-gui-parity..."
bash scripts/lint-gui-parity.sh

echo "pre-commit: lint-every-verb-has-e2e..."
bash scripts/lint-every-verb-has-e2e.sh

echo "pre-commit: lint-file-size..."
bash scripts/lint-file-size.sh

echo "pre-commit: lint-function-size..."
bash scripts/lint-function-size.sh

echo "pre-commit: lint-cyclomatic-complexity..."
bash scripts/lint-cyclomatic-complexity.sh

echo "pre-commit: lint-naming..."
bash scripts/lint-naming.sh

echo "pre-commit: lint-public-surface (soft)..."
bash scripts/lint-public-surface.sh

echo "pre-commit: lint-crash-regression..."
bash scripts/lint-crash-regression.sh

echo "pre-commit: lint-rendering-pixel-dims..."
bash scripts/lint-rendering-pixel-dims.sh

echo "pre-commit: lint-no-fakes..."
bash scripts/lint-no-fakes.sh

echo "pre-commit: lint-github-tickets (soft)..."
bash scripts/lint-github-tickets.sh

echo "pre-commit: release build (warnings-as-errors)..."
swift build -c release -Xswiftc -warnings-as-errors >/dev/null

echo "pre-commit: hermetic tests..."
swift test --parallel >/dev/null

# Verify the man page is in sync with the binary.
EXPECTED=$(.build/release/wdm manpage)
ACTUAL=$(cat man/wdm.1 2>/dev/null || true)
# The .TH header includes a date; strip the date line before diffing.
norm() { sed 's/^\.TH WDM 1 ".*"/\.TH WDM 1 "DATE"/'; }
if [ "$(printf '%s' "$EXPECTED" | norm)" != "$(printf '%s' "$ACTUAL" | norm)" ]; then
    echo "pre-commit: man/wdm.1 is out of date with the binary."
    echo "  Run: .build/release/wdm manpage > man/wdm.1 && git add man/wdm.1"
    exit 1
fi

echo "pre-commit: ok"
